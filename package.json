{
  "name": "lorraine-ipsum",
  "version": "1.0.0",
  "description": "A compact Lorraine-themed Lorem Ipsum generator.",
  "private": true,
  "scripts": {
    "build": "gulp build",
    "build:prod": "gulp build --production",
    "check": "npm run lint && npm run build:prod && node --check build/js/main.js",
    "dev": "gulp",
    "format": "prettier --write \"*.{js,json,md}\" \"source/index.html\" \"source/scss/**/*.scss\" \"source/js/frontend.js\" \"source/js/lorraine-ipsum/*.js\"",
    "lint": "prettier --check \"*.{js,json,md}\" \"source/index.html\" \"source/scss/**/*.scss\" \"source/js/frontend.js\" \"source/js/lorraine-ipsum/*.js\"",
    "watch": "gulp watch"
  },
  "keywords": [
    "lorem-ipsum",
    "generator",
    "lorraine",
    "static-site",
    "gulp"
  ],
  "author": "Thomas Pericoi",
  "license": "ISC",
  "engines": {
    "node": ">=20.19"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ThomasPericoi/LorraineIpsum.git"
  },
  "bugs": {
    "url": "https://github.com/ThomasPericoi/LorraineIpsum/issues"
  },
  "homepage": "https://lorraineipsum.fr/",
  "devDependencies": {
    "gulp": "^5.0.1",
    "gulp-clean-css": "^4.3.0",
    "gulp-concat": "^2.6.1",
    "gulp-sass": "^6.0.1",
    "gulp-terser": "^2.1.0",
    "prettier": "^3.7.4",
    "sass": "^1.101.0"
  }
}
